# LLM provider. Use "anthropic" for /v1/messages, or "openai" for /v1/chat/completions.
LLM_API_TYPE=anthropic
LLM_API_URL=https://your-llm-endpoint.example/v1/messages
LLM_API_KEY=replace-with-your-key
LLM_MODEL=qwen3.5-plus
LLM_STREAM=false
LLM_SSL_VERIFY=true
LLM_MAX_CALLS_PER_MINUTE=15
LLM_MAX_RETRIES=2
LLM_REQUEST_TIMEOUT=90
LLM_VISION_TIMEOUT=60
LLM_STREAM_READ_TIMEOUT=90
LLM_STREAM_WALL_TIMEOUT=180
ANTHROPIC_VERSION=2023-06-01
VISION_MODEL=qwen3.5-plus

# Cost controls. balanced avoids LLM calls for triage/rerank/WBS routing.
AUDIT_COST_PROFILE=balanced
RAG_RERANK_MODE=local
TRIAGE_MODE=local
AGENT_ROUTING_ENABLED=true
AGENT_MAX_SCHEME_AGENTS=5
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_DAYS=30
LLM_FAILURE_CACHE_TTL_SECONDS=600

# V2 repair-scheme audit engine. Keeps legacy engine available via AUDIT_ENGINE=legacy.
AUDIT_ENGINE=v2_repair
REVIEW_EXPERIENCE_ENABLED=true
COST_REVIEW_MODE=explicit
REPAIR_AI_REVIEW_ENABLED=true
REPAIR_AI_REVIEW_MODE=adaptive
REPAIR_AI_CALL_BUDGET=2
REPAIR_TOOL_QUERY_LIMIT=6
REPAIR_TOOL_RESULT_CHARS=2400
REPAIR_AI_REVIEW_TIMEOUT=180
REPAIR_AI_REVIEW_MAX_TOKENS=4096
REPAIR_CROSS_PROJECT_EXPERIENCE=true
REPAIR_CROSS_PROJECT_MIN_OVERLAP=2
REPAIR_CROSS_PROJECT_MATCH_LIMIT=4
REPAIR_EXPERIENCE_MATCH_LIMIT=8
INCLUDE_EXPERIENCE_IN_STANDARD_RAG=false

# Optional reasoning/thinking mode for supported models. V2 repair uses a bounded AI call budget.
LLM_THINKING_ENABLED=true
LLM_THINKING_BUDGET_TOKENS=1024
LLM_REASONING_EFFORT=medium

# PageIndex tree-index generation
PAGEINDEX_ROOT=/path/to/PageIndex
PAGEINDEX_MODEL=qwen3.5-plus
PAGEINDEX_LLM_TIMEOUT=180
PAGEINDEX_LLM_HARD_TIMEOUT=200
PAGEINDEX_LLM_RETRIES=3
PAGEINDEX_STANDARD_TOC_FALLBACK=1
PAGEINDEX_TOC_FIX_MAX_ATTEMPTS=0
PAGEINDEX_STANDARD_TOC_MAX_SPAN=12
PAGEINDEX_OCR_FALLBACK=auto
PAGEINDEX_OCR_ENGINE=auto
PAGEINDEX_OCR_CACHE=1
PAGEINDEX_OCR_CACHE_DIR=auto_review_system/data/pageindex_ocr_cache
PAGEINDEX_MIN_TEXT_CHARS=1000
PAGEINDEX_MIN_TEXT_PAGE_RATIO=0.2
PAGEINDEX_MIN_PAGE_TEXT_CHARS=20

# Optional: required for online PaddleOCR engines. Without this, auto falls back to local RapidOCR if installed.
PADDLE_API_TOKEN=replace-with-your-paddle-token
PADDLE_MAX_PAGES_PER_REQUEST=100
